</span><span class="n">tests</span><span class="w">  </span><span class="o">&lt;-</span><span class="w"> </span><span class="n">paste0</span><span class="p">(</span><span class="s2">"G"</span><span class="p">,</span><span class="w">     </span><span class="n">sprintf</span><span class="p">(</span><span class="s2">"%02d"</span><span class="p">,</span><span class="w"> </span><span class="m">1</span><span class="o">:</span><span class="n">n_test</span><span class="p">))</span><span class="w">

</span><span class="n">aug_design</span><span class="w"> </span><span class="o">&lt;-</span><span class="w"> </span><span class="n">design.augmented</span><span class="p">(</span><span class="w">
  </span><span class="n">trt</span><span class="w">    </span><span class="o">=</span><span class="w"> </span><span class="n">tests</span><span class="p">,</span><span class="w">
