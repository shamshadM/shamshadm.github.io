 Residual               5.71    2.390
</code></pre></div></div>

<div class="language-r highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="c1"># ── Heritability estimate ─────────────────────────────────────────────────</span><span class="w">
</span><span class="c1"># H² = σ²_g / (σ²_g + σ²_e/r)</span><span class="w">
</span><span class="n">vc</span><span class="w">         </span><span class="o">&lt;-</span><span class="w"> </span><span class="n">as.data.frame</span><span class="p">(</span><span class="n">VarCorr</span><span class="p">(</span><span class="n">model_mixed</span><span class="p">))</span><span class="w">
</span><span class="n">sigma2_e</span><span class="w">   </span><span class="o">&lt;-</span><span class="w"> </span><span class="n">sigma</span><span class="p">(</span><span class="n">model_mixed</span><span class="p">)</span><span class="o">^</span><span class="m">2</span><span class="w">
</span><span class="n">sigma2_b</span><span class="w">   </span><span class="o">&lt;-</span><span class="w"> </span><span class="n">vc</span><span class="p">[</span><span class="n">vc</span><span class="o">$</span><span class="n">grp</span><span class="w"> </span><span class="o">==</span><span class="w"> </span><span class="s2">"rep_block"</span><span class="p">,</span><span class="w"> </span><span class="s2">"vcov"</span><span class="p">]</span><span class="w">

</span><span class="c1"># Genotype variance from fixed effects MS</span><span class="w">
</span><span class="n">MS_geno</span><span class="w">    </span><span class="o">&lt;-</span><span class="w"> </span><span class="n">anova</span><span class="p">(</span><span class="n">model_mixed</span><span class="p">)[</span><span class="s2">"trt"</span><span class="p">,</span><span class="w"> </span><span class="s2">"Mean Sq"</span><span class="p">]</span><span class="w">
</span><span class="n">sigma2_g</span><span class="w">   </span><span class="o">&lt;-</span><span class="w"> </span><span class="p">(</span><span class="n">MS_geno</span><span class="w"> </span><span class="o">-</span><span class="w"> </span><span class="n">sigma2_e</span><span class="p">)</span><span class="w"> </span><span class="o">/</span><span class="w"> </span><span class="n">r</span><span class="w">

</span><span class="n">H2</span><span class="w"> </span><span class="o">&lt;-</span><span class="w"> </span><span class="n">sigma2_g</span><span class="w"> </span><span class="o">/</span><span class="w"> </span><span class="p">(</span><span class="n">sigma2_g</span><span class="w"> </span><span class="o">+</span><span class="w"> </span><span class="n">sigma2_e</span><span class="w"> </span><span class="o">/</span><span class="w"> </span><span class="n">r</span><span class="p">)</span><span class="w">
</span><span class="n">cat</span><span class="p">(</span><span class="s2">"Broad-sense heritability H²:"</span><span class="p">,</span><span class="w"> </span><span class="nf">round</span><span class="p">(</span><span class="n">H2</span><span class="p">,</span><span class="w"> </span><span class="m">3</span><span class="p">),</span><span class="w"> </span><span class="s2">"\n"</span><span class="p">)</span><span class="w">
</span></code></pre></div></div>

