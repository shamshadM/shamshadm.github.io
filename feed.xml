<h2 id="12-ar1ar1-vs-alternative-spatial-models">12. AR1×AR1 vs Alternative Spatial Models</h2>

<table>
  <thead>
    <tr>
      <th>Model</th>
      <th>Assumptions</th>
      <th>Flexibility</th>
      <th>R package</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td>AR1×AR1</td>
