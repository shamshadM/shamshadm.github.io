  </span><span class="n">Yield</span><span class="w"> </span><span class="o">~</span><span class="w"> </span><span class="n">trt</span><span class="w"> </span><span class="o">+</span><span class="w"> </span><span class="n">Square</span><span class="w"> </span><span class="o">+</span><span class="w"> </span><span class="n">Row</span><span class="w"> </span><span class="o">%in%</span><span class="w"> </span><span class="n">Square</span><span class="w"> </span><span class="o">+</span><span class="w"> </span><span class="n">Col</span><span class="w"> </span><span class="o">%in%</span><span class="w"> </span><span class="n">Square</span><span class="p">,</span><span class="w">
  </span><span class="n">data</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="n">rep_book</span><span class="w">
</span><span class="p">)</span><span class="w">
</span><span class="n">summary</span><span class="p">(</span><span class="n">model_rep</span><span class="p">)</span><span class="w">

</span><span class="n">cat</span><span class="p">(</span><span class="s2">"Error df (replicated):"</span><span class="p">,</span><span class="w"> </span><span class="p">(</span><span class="n">t_rep</span><span class="w"> </span><span class="o">-</span><span class="w"> </span><span class="m">1</span><span class="p">)</span><span class="w"> </span><span class="o">*</span><span class="w"> </span><span class="p">(</span><span class="n">t_rep</span><span class="w"> </span><span class="o">-</span><span class="w"> </span><span class="m">2</span><span class="p">)</span><span class="w"> </span><span class="o">*</span><span class="w"> </span><span class="n">n_rep</span><span class="p">,</span><span class="w"> </span><span class="s2">"\n"</span><span class="p">)</span><span class="w">
