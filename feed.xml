  </span><span class="n">BLUP</span><span class="w">  </span><span class="o">=</span><span class="w"> </span><span class="n">rc_blups</span><span class="p">[[</span><span class="s2">"(Intercept)"</span><span class="p">]]</span><span class="w">
</span><span class="p">)</span><span class="w"> </span><span class="o">|&gt;</span><span class="w"> </span><span class="n">arrange</span><span class="p">(</span><span class="n">desc</span><span class="p">(</span><span class="n">BLUP</span><span class="p">))</span><span class="w">

</span><span class="n">head</span><span class="p">(</span><span class="n">rc_blup_df</span><span class="p">,</span><span class="w"> </span><span class="m">10</span><span class="p">)</span><span class="w">
