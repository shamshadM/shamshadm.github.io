</span><span class="c1"># Effect size f from current η²</span><span class="w">
</span><span class="n">eta2</span><span class="w">   </span><span class="o">&lt;-</span><span class="w"> </span><span class="n">SS_trt</span><span class="w"> </span><span class="o">/</span><span class="w"> </span><span class="n">SS_total</span><span class="w">
