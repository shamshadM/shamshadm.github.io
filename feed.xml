      <td>Factor A</td>
      <td>$a - 1$</td>
      <td>$SS_A$</td>
      <td>$MS_A$</td>
      <td>$MS_A / MS_E$</td>
    </tr>
    <tr>
      <td>Factor B</td>
      <td>$b - 1$</td>
      <td>$SS_B$</td>
      <td>$MS_B$</td>
