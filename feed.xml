<h3 id="step-2--generate-latin-square-layout">Step 2 — Generate Latin Square Layout</h3>

<div class="language-r highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="c1"># ── Design: 5 × 5 Latin Square (5 treatments) ────────────────────────────</span><span class="w">
</span><span class="n">set.seed</span><span class="p">(</span><span class="m">42</span><span class="p">)</span><span class="w">
</span><span class="n">t</span><span class="w">          </span><span class="o">&lt;-</span><span class="w"> </span><span class="m">5</span><span class="w">
</span><span class="n">treatments</span><span class="w"> </span><span class="o">&lt;-</span><span class="w"> </span><span class="n">paste0</span><span class="p">(</span><span class="s2">"T"</span><span class="p">,</span><span class="w"> </span><span class="m">1</span><span class="o">:</span><span class="n">t</span><span class="p">)</span><span class="w">

</span><span class="n">lsd_design</span><span class="w"> </span><span class="o">&lt;-</span><span class="w"> </span><span class="n">design.lsd</span><span class="p">(</span><span class="w">
  </span><span class="n">trt</span><span class="w">  </span><span class="o">=</span><span class="w"> </span><span class="n">treatments</span><span class="p">,</span><span class="w">
  </span><span class="n">seed</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="m">42</span><span class="w">
</span><span class="p">)</span><span class="w">

</span><span class="c1"># The $sketch gives the t×t matrix; $book gives the field book</span><span class="w">
</span><span class="n">sketch</span><span class="w">    </span><span class="o">&lt;-</span><span class="w"> </span><span class="n">lsd_design</span><span class="o">$</span><span class="n">sketch</span><span class="w">
</span><span class="n">field_book</span><span class="w"> </span><span class="o">&lt;-</span><span class="w"> </span><span class="n">lsd_design</span><span class="o">$</span><span class="n">book</span><span class="w">

</span><span class="n">cat</span><span class="p">(</span><span class="s2">"Latin Square Layout (sketch):\n"</span><span class="p">)</span><span class="w">
</span><span class="n">print</span><span class="p">(</span><span class="n">sketch</span><span class="p">)</span><span class="w">
</span><span class="n">cat</span><span class="p">(</span><span class="s2">"\nField book (first 10 rows):\n"</span><span class="p">)</span><span class="w">
</span><span class="n">print</span><span class="p">(</span><span class="n">head</span><span class="p">(</span><span class="n">field_book</span><span class="p">,</span><span class="w"> </span><span class="m">10</span><span class="p">))</span><span class="w">
</span><span class="n">cat</span><span class="p">(</span><span class="s2">"\nDesign parameters\n"</span><span class="p">)</span><span class="w">
</span><span class="n">cat</span><span class="p">(</span><span class="s2">"  Treatments :"</span><span class="p">,</span><span class="w"> </span><span class="n">t</span><span class="p">,</span><span class="w"> </span><span class="s2">"\n"</span><span class="p">)</span><span class="w">
</span><span class="n">cat</span><span class="p">(</span><span class="s2">"  Rows       :"</span><span class="p">,</span><span class="w"> </span><span class="n">t</span><span class="p">,</span><span class="w"> </span><span class="s2">"\n"</span><span class="p">)</span><span class="w">
</span><span class="n">cat</span><span class="p">(</span><span class="s2">"  Columns    :"</span><span class="p">,</span><span class="w"> </span><span class="n">t</span><span class="p">,</span><span class="w"> </span><span class="s2">"\n"</span><span class="p">)</span><span class="w">
</span><span class="n">cat</span><span class="p">(</span><span class="s2">"  Total plots:"</span><span class="p">,</span><span class="w"> </span><span class="n">t</span><span class="o">^</span><span class="m">2</span><span class="p">,</span><span class="w"> </span><span class="s2">"\n"</span><span class="p">)</span><span class="w">
</span><span class="n">cat</span><span class="p">(</span><span class="s2">"  Error df   :"</span><span class="p">,</span><span class="w"> </span><span class="p">(</span><span class="n">t</span><span class="m">-1</span><span class="p">)</span><span class="o">*</span><span class="p">(</span><span class="n">t</span><span class="m">-2</span><span class="p">),</span><span class="w"> </span><span class="s2">"\n"</span><span class="p">)</span><span class="w">
</span></code></pre></div></div>

