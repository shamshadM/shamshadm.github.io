</span><span class="n">model</span><span class="w"> </span><span class="o">&lt;-</span><span class="w"> </span><span class="n">lme</span><span class="p">(</span><span class="n">yield</span><span class="w"> </span><span class="o">~</span><span class="w"> </span><span class="n">irrigation</span><span class="w"> </span><span class="o">*</span><span class="w"> </span><span class="n">nitrogen</span><span class="p">,</span><span class="w">
