           </span><span class="o">+</span><span class="w"> </span><span class="n">vsr</span><span class="p">(</span><span class="n">ROW_f</span><span class="p">,</span><span class="w"> </span><span class="n">Gu</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="n">AR1</span><span class="p">(</span><span class="n">field_book</span><span class="o">$</span><span class="n">ROW_f</span><span class="p">,</span><span class="w"> </span><span class="n">rho</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="m">0.7</span><span class="p">))</span><span class="w">
           </span><span class="o">+</span><span class="w"> </span><span class="n">vsr</span><span class="p">(</span><span class="n">COL_f</span><span class="p">,</span><span class="w"> </span><span class="n">Gu</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="n">AR1</span><span class="p">(</span><span class="n">field_book</span><span class="o">$</span><span class="n">COL_f</span><span class="p">,</span><span class="w"> </span><span class="n">rho</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="m">0.6</span><span class="p">)),</span><span class="w">
  </span><span class="n">data</span><span class="w">   </span><span class="o">=</span><span class="w"> </span><span class="n">field_book</span><span class="p">,</span><span class="w">
  </span><span class="n">verbose</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="kc">FALSE</span><span class="w">
</span><span class="p">)</span><span class="w">

