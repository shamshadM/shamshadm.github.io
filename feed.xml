</span><span class="n">cat</span><span class="p">(</span><span class="s2">"  Error df        :"</span><span class="p">,</span><span class="w"> </span><span class="p">(</span><span class="n">n_checks</span><span class="w"> </span><span class="o">-</span><span class="w"> </span><span class="m">1</span><span class="p">)</span><span class="w"> </span><span class="o">*</span><span class="w"> </span><span class="p">(</span><span class="n">n_blocks</span><span class="w"> </span><span class="o">-</span><span class="w"> </span><span class="m">1</span><span class="p">),</span><span class="w"> </span><span class="s2">"\n"</span><span class="p">)</span><span class="w">
