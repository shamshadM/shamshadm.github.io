  </span><span class="n">PEV</span><span class="w">    </span><span class="o">=</span><span class="w"> </span><span class="n">spats_preds</span><span class="o">$</span><span class="n">standard.errors</span><span class="o">^</span><span class="m">2</span><span class="p">,</span><span class="w">
  </span><span class="n">Acc</span><span class="w">    </span><span class="o">=</span><span class="w"> </span><span class="nf">sqrt</span><span class="p">(</span><span class="m">1</span><span class="w"> </span><span class="o">-</span><span class="w"> </span><span class="n">spats_preds</span><span class="o">$</span><span class="n">standard.errors</span><span class="o">^</span><span class="m">2</span><span class="w"> </span><span class="o">/</span><span class="w">
