  </span><span class="n">tibble</span><span class="o">::</span><span class="n">rownames_to_column</span><span class="p">(</span><span class="s2">"Genotype"</span><span class="p">)</span><span class="w"> </span><span class="o">|&gt;</span><span class="w">
  </span><span class="n">arrange</span><span class="p">(</span><span class="n">desc</span><span class="p">(</span><span class="n">Yield</span><span class="p">))</span><span class="w">
</span><span class="n">print</span><span class="p">(</span><span class="n">lsd_groups</span><span class="p">)</span><span class="w">
