source "https://rubygems.org"

# Dart Sass (required for @use / @forward module system)
# jekyll-sass-converter >= 3.0 uses sass-embedded (Dart Sass) instead of Ruby Sass.
# Run: bundle install   (first time or after editing)
# Run: bundle exec jekyll serve
gem "jekyll-sass-converter", "~> 3.0"
gem "sass-embedded"
#  gem 'jekyll-brotli'

gem "jekyll", "~> 4.4.1"
gem 'tzinfo-data'
gem "wdm" if Gem.win_platform?

# Plugins
group :jekyll_plugins do
  gem 'jekyll-sitemap'
  gem 'jekyll-paginate'
  gem 'commonmarker'
  gem 'jekyll-gist'
  gem 'jekyll-seo-tag'
  gem "kramdown"
  gem "kramdown-parser-gfm"
  gem 'jekyll-archives'
  gem 'jekyll-feed'
  gem 'jekyll-include-cache'
  gem 'jekyll-redirect-from'
  gem 'webrick'
  gem 'faraday-retry'
  gem 'jekyll-last-modified-at'
  gem 'jekyll-gzip'
  gem 'jemoji'
end
